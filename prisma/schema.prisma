// Personal portfolio schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id           Int      @id @default(autoincrement())
  title        String   @db.VarChar(255)
  slug         String   @unique @db.VarChar(255)
  description  String
  imageUrl     String?  @db.VarChar(500)
  technologies String[]
  githubUrl    String?  @db.VarChar(500)
  liveUrl      String?  @db.VarChar(500)
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([published])
  @@map("projects")
}

model BlogPost {
  id           Int       @id @default(autoincrement())
  title        String    @db.VarChar(255)
  slug         String    @unique @db.VarChar(255)
  excerpt      String?   @db.VarChar(500)
  content      String
  coverImageUrl String?  @db.VarChar(500)
  published    Boolean   @default(false)
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([published])
  @@index([publishedAt(sort: Desc)])
  @@map("blog_posts")
}

model Experience {
  id          Int      @id @default(autoincrement())
  company     String   @db.VarChar(255)
  position    String   @db.VarChar(255)
  startDate   DateTime
  endDate     DateTime?
  description String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([orderIndex])
  @@map("experiences")
}

model ContactInfo {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(100)
  value     String   @db.VarChar(500)
  createdAt DateTime @default(now())

  @@map("contact_info")
}

model ContactSubmission {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  email       String   @db.VarChar(255)
  subject     String?  @db.VarChar(255)
  message     String
  ipAddress   String?  @db.VarChar(45)
  userAgent   String?  @db.VarChar(500)
  spamScore   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([email])
  @@map("contact_submissions")
}

model AdminOtpCode {
  id         Int      @id @default(autoincrement())
  email      String   @db.VarChar(255)
  codeHash   String   @db.VarChar(128)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([email, expiresAt])
  @@map("admin_otp_codes")
}

model AdminSession {
  id         Int      @id @default(autoincrement())
  email      String   @db.VarChar(255)
  tokenHash  String   @unique @db.VarChar(128)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([email, expiresAt])
  @@map("admin_sessions")
}

